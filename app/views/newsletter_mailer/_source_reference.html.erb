<% if article.source_url.present? %>
  <div class="source-reference" style="background: #f5f5f5; padding: 12px; margin: 16px 0; border-left: 3px solid #ddd;">
    <% if article.source_author.present? %>
      <p style="margin: 0 0 8px 0; font-size: 14px; color: #666;">
        <strong>Source:</strong> <%= article.source_author %>
      </p>
    <% end %>
    <% if article.source_content.present? %>
      <blockquote style="margin: 8px 0; padding-left: 12px; border-left: 2px solid #ccc; color: #555; font-style: italic;">
        <%= article.source_content %>
      </blockquote>
    <% end %>
    <p style="margin: 8px 0 0 0; font-size: 12px;">
      <a href="<%= article.source_url %>" style="color: #0066cc;">View original source</a>
    </p>
  </div>
<% end %>
